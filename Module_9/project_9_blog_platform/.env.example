# .env.example — copy to .env for local dev (never commit the real .env).
# Locally you can leave these blank: the app defaults to SQLite + DEBUG=True.
SECRET_KEY=django-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=*
# Set DATABASE_URL to a Postgres URL in production (Render fills this in):
# DATABASE_URL=postgres://user:pass@host:5432/dbname
