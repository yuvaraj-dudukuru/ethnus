# ============================================================================
#  .env.example — copy to ".env" for local dev. Never commit the real ".env".
# ============================================================================
SECRET_KEY=replace-with-a-50-char-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Blank locally = SQLite. On Render, paste the Postgres Internal Database URL.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Media storage -----------------------------------------------------------
# USE_S3=False : photos saved to local disk (ephemeral on Render — resets on redeploy)
# USE_S3=True  : photos saved to Amazon S3 (persistent). Fill the AWS_* keys below.
USE_S3=False
# AWS_ACCESS_KEY_ID=your-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=campushub-media
# AWS_S3_REGION_NAME=us-east-1
