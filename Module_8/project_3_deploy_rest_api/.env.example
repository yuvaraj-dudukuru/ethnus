# ============================================================================
#  .env.example — copy to ".env" for local dev. Never commit the real ".env".
# ============================================================================
SECRET_KEY=replace-with-a-50-char-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Blank locally = SQLite. On Render, paste the Postgres Internal Database URL.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Comma-separated browser origins allowed to call this API (CORS).
# CORS_ALLOWED_ORIGINS=https://my-frontend.example.com
