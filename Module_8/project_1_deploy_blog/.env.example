# ============================================================================
#  .env.example — copy to ".env" for local development and fill in values.
#  NEVER commit the real ".env" (it is in .gitignore). On Render, set these
#  same keys in the dashboard under Environment instead of using a file.
# ============================================================================

# A long random string. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=replace-with-a-50-char-random-secret-key

# "True" locally, "False" in production.
DEBUG=True

# Comma-separated hostnames allowed to serve the site.
ALLOWED_HOSTS=localhost,127.0.0.1

# Database connection string.
# Leave BLANK locally to use the bundled SQLite file (db.sqlite3).
# On Render, paste the PostgreSQL "Internal Database URL".
# DATABASE_URL=postgres://user:password@host:5432/dbname
