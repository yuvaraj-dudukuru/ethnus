# ============================================================================
#  .env.example — copy to ".env" for local dev. Never commit the real ".env".
# ============================================================================
SECRET_KEY=replace-with-a-50-char-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Blank locally = SQLite. On Render, paste the Postgres Internal Database URL.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Persistent product images on S3 (real deploy) ---
USE_S3=False
# AWS_ACCESS_KEY_ID=your-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=ecommerce-media
# AWS_S3_REGION_NAME=us-east-1

# --- Error tracking (optional) ---
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# ENVIRONMENT=production
